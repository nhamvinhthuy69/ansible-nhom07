#!/bin/bash
set -euo pipefail
BACKUP_DIR="{{ backup_dir }}"
DATE=$(date +%Y%m%d_%H%M%S)
RETENTION={{ backup_retention_days }}

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"; }

backup_db() {
    log "Starting DB backup..."
    mysqldump -u root -p'{{ db_root_password }}' \
        --single-transaction --routines --triggers \
        {{ db_name }} | gzip > "$BACKUP_DIR/db/{{ db_name }}_$DATE.sql.gz"
    log "DB backup done."
}

backup_nfs() {
    log "Starting NFS backup..."
    tar -czf "$BACKUP_DIR/nfs/wordpress_$DATE.tar.gz" \
        -C "{{ nfs_share_path }}" --exclude="wp-content/cache" .
    log "NFS backup done."
}

cleanup() {
    find "$BACKUP_DIR" -name "*.gz" -mtime +$RETENTION -delete
    log "Cleanup done."
}

case "${1:-}" in
    db)   backup_db;  cleanup ;;
    nfs)  backup_nfs; cleanup ;;
    full) backup_db; backup_nfs; cleanup ;;
    *)    echo "Usage: $0 [db|nfs|full]"; exit 1 ;;
esac
